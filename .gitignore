# Repo-local assets and generated data.
# Anchored to the repo root: unanchored `data/` also matched `conf/data/`,
# which silently kept the Hydra data config group out of Git.
/TreeFormer_assets/
/data/
/datasets/
/trained_weights/
/runs/
/outputs/

# Local secrets and machine-specific environment
.env
.env.*
!.env.example
.agents/
temp/

# Model checkpoints, archives, and training dumps
*.pkl
*.pth
*.pt
*.npz
*.tar
*.tar.gz
*.tgz
events.out.tfevents*

# Python environments, caches, and package metadata
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/

# Build artifacts
build/
dist/
models/ops/build/
